{
  "name": "planscope-web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build:wasm": "bash ../scripts/build-wasm.sh",
    "predev": "npm run build:wasm",
    "pretest": "npm run build:wasm",
    "dev": "vite",
    "prebuild": "npm run build:wasm",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "pretest:coverage": "npm run build:wasm",
    "test:coverage": "vitest run --coverage",
    "prelint": "npm run build:wasm",
    "lint": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^20.19.43",
    "@vitest/coverage-v8": "^4.1.10",
    "jsdom": "^29.1.1",
    "typescript": "^7.0.2",
    "vite": "^8.1.5",
    "vitest": "^4.1.10"
  }
}
